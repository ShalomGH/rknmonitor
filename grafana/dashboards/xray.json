          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  x.checked_at AS time,\n  pn.name AS agent,\n  x.profile_name AS profile,\n  COALESCE(x.subscription_name, 'default') AS subscription,\n  x.protocol || ' / ' || COALESCE(x.transport, 'unknown') || ' / ' || COALESCE(x.security, 'none') AS technology,\n  COALESCE(x.transport, 'unknown') AS transport,\n  x.server_host || ':' || x.server_port AS server,\n  COALESCE(x.error_type, '') AS error_type,\n  left(COALESCE(x.error, ''), 220) AS error\nFROM xray_probe_results x\nJOIN probe_nodes pn ON pn.id = x.probe_node_id\nWHERE NOT x.ok\n  AND pn.name IN (${agent:sqlstring})\n  AND COALESCE(x.subscription_name, 'default') IN (${subscription:sqlstring})\n  AND x.protocol IN (${protocol:sqlstring})\n  AND COALESCE(x.transport, 'unknown') IN (${transport:sqlstring})\n  AND COALESCE(x.security, 'none') IN (${security:sqlstring})\n  AND $__timeFilter(x.checked_at)\nORDER BY x.checked_at DESC\nLIMIT 100;"
        }
      ],
