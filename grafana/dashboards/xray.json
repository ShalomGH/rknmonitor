              "options": "success_pct"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percent"
              }
            ]
          }
        ]
      }
    },
    {
      "id": 11,
      "title": "Status history by technology/profile",
      "type": "timeseries",
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "grafana-postgres"
          },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  x.checked_at AS \"time\",\n  x.protocol || ' / ' || COALESCE(x.transport, 'unknown') || ' / ' || COALESCE(x.security, 'none') || ' / ' || x.profile_name AS metric,\n  CASE WHEN x.ok THEN 1 ELSE 0 END AS value\nFROM xray_probe_results x\nJOIN probe_nodes pn ON pn.id = x.probe_node_id\nWHERE pn.name IN (${agent:sqlstring})\n  AND COALESCE(x.subscription_name, 'default') IN (${subscription:sqlstring})\n  AND x.protocol IN (${protocol:sqlstring})\n  AND COALESCE(x.transport, 'unknown') IN (${transport:sqlstring})\n  AND COALESCE(x.security, 'none') IN (${security:sqlstring})\n  AND $__timeFilter(x.checked_at)\nORDER BY x.checked_at;"
        }
