    {
      "id": 9,
      "title": "Latest profile state",
      "type": "table",
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "grafana-postgres"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH latest AS (\n  SELECT DISTINCT ON (x.probe_node_id, COALESCE(x.subscription_name, 'default'), x.profile_id)\n    pn.name AS agent,\n    x.profile_name AS profile,\n    COALESCE(x.subscription_name, 'default') AS subscription,\n    x.protocol || ' / ' || COALESCE(x.transport, 'unknown') || ' / ' || COALESCE(x.security, 'none') AS technology,\n    x.protocol,\n    COALESCE(x.transport, 'unknown') AS transport,\n    COALESCE(x.security, 'none') AS security,\n    COALESCE(x.fingerprint, '') AS fingerprint,\n    x.server_host || ':' || x.server_port AS server,\n    x.socks_port,\n    CASE\n      WHEN x.checked_at < now() - interval '15 minutes' THEN 'STALE'\n      WHEN x.ok THEN 'OK'\n      ELSE 'FAILED'\n    END AS status,\n    round(x.latency_ms::numeric, 1) AS latency_ms,\n    x.http_status,\n    COALESCE(x.error_type, '') AS error_type,\n    left(COALESCE(x.error, ''), 180) AS error,\n    x.checked_at AS last_check,\n    now() - x.checked_at AS age\n  FROM xray_probe_results x\n  JOIN probe_nodes pn ON pn.id = x.probe_node_id\n  WHERE pn.name IN (${agent:sqlstring})\n    AND COALESCE(x.subscription_name, 'default') IN (${subscription:sqlstring})\n    AND x.protocol IN (${protocol:sqlstring})\n    AND COALESCE(x.transport, 'unknown') IN (${transport:sqlstring})\n    AND COALESCE(x.security, 'none') IN (${security:sqlstring})\n  ORDER BY x.probe_node_id, COALESCE(x.subscription_name, 'default'), x.profile_id, x.checked_at DESC\n)\nSELECT * FROM latest\nORDER BY\n  CASE status WHEN 'FAILED' THEN 0 WHEN 'STALE' THEN 1 ELSE 2 END,\n  age DESC, technology, profile;"
        }
      ],
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 12
      },
      "datasource": {
        "type": "postgres",
        "uid": "grafana-postgres"
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "status"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "latency_ms"
            },
            "properties": [
              {
                "id": "unit",
                "value": "ms"
              }
            ]
          }
        ]
      }
    },
    {
      "id": 10,
      "title": "Success by technology",
      "type": "table",
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "grafana-postgres"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH latest AS (\n  SELECT DISTINCT ON (x.probe_node_id, COALESCE(x.subscription_name, 'default'), x.profile_id)\n    x.protocol || ' / ' || COALESCE(x.transport, 'unknown') || ' / ' || COALESCE(x.security, 'none') AS technology,\n    x.ok,\n    x.checked_at\n  FROM xray_probe_results x\n  JOIN probe_nodes pn ON pn.id = x.probe_node_id\n  WHERE pn.name IN (${agent:sqlstring})\n    AND COALESCE(x.subscription_name, 'default') IN (${subscription:sqlstring})\n    AND x.protocol IN (${protocol:sqlstring})\n    AND COALESCE(x.transport, 'unknown') IN (${transport:sqlstring})\n    AND COALESCE(x.security, 'none') IN (${security:sqlstring})\n  ORDER BY x.probe_node_id, COALESCE(x.subscription_name, 'default'), x.profile_id, x.checked_at DESC\n)\nSELECT\n  technology,\n  count(*) AS total,\n  count(*) FILTER (WHERE ok AND checked_at >= now() - interval '15 minutes') AS ok,\n  count(*) FILTER (WHERE NOT ok AND checked_at >= now() - interval '15 minutes') AS failed,\n  count(*) FILTER (WHERE checked_at < now() - interval '15 minutes') AS stale,\n  round(100.0 * count(*) FILTER (WHERE ok AND checked_at >= now() - interval '15 minutes') / NULLIF(count(*) FILTER (WHERE checked_at >= now() - interval '15 minutes'), 0), 1) AS success_pct\nFROM latest\nGROUP BY technology\nORDER BY failed DESC, stale DESC, technology;"
        }
      ],
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 0,
        "y": 22
      },
