CENTRAL_API_URL=https://mon.example.com
NODE_API_KEY=replace-me
AGENT_NAME=rknmon-agent-rpi-home
AGENT_LOCATION=home
AGENT_PROVIDER=domru
# subject = network under test; control/external = comparison vantage
AGENT_ROLE=subject
AGENT_VERSION=0.1.0
PUBLIC_IP=
PROBE_INTERVAL_SECONDS=300
PROBE_CONCURRENCY=20

XRAY_ENABLED=false
XRAY_SUBSCRIPTION_URLS=https://sub.example/sub-token,https://198.51.100.10/sub-token
XRAY_TEST_URL=https://cp.cloudflare.com/
XRAY_SOCKS_START_PORT=11001
XRAY_CONFIG_PATH=/config/xray.generated.json
XRAY_WAIT_FOR_SOCKS=true
XRAY_READY_TIMEOUT_SECONDS=90

DPI_ENABLED=false
DPI_TARGETS=YouTube=www.youtube.com,Discord=discord.com,Telegram=api.telegram.org,GitHub=github.com,Cloudflare=cloudflare.com
DPI_WHITELISTED_URLS=https://ya.ru/,https://vk.ru/,https://max.ru/
DPI_REGULAR_URLS=https://github.com/,https://www.google.com/,https://ru.wikipedia.org/
DPI_TIMEOUT_SECONDS=10
DPI_L4_PAYLOAD_BYTES=65536

# Controlled blocking-mechanism experiments. Keep disabled until you configure
# endpoints that you own or are explicitly authorized to test.
DPI_EXPERIMENTS_ENABLED=false
# Same endpoint/IP, different SNI variants. "correct" uses URL host, "none" omits SNI.
DPI_EXPERIMENT_TARGETS=control=https://control.example.com/
DPI_SNI_VARIANTS=correct,none,bogus.invalid
# Same TLS connection/SNI, different HTTP Host values.
DPI_HOST_VARIANTS=correct,control-alt.example.com
# UDP echo endpoints must echo the exact datagram payload.
DPI_UDP_TARGETS=echo=203.0.113.10:9443
# Real HTTP/3 probes use curl --http3-only when supported by the installed curl.
DPI_HTTP3_TARGETS=https://cloudflare-quic.com/
# Optional forensic artifacts retained only for failed controlled experiments.
DPI_ARTIFACT_DIR=/var/lib/rknmon/artifacts
DPI_CAPTURE_ON_ANOMALY=false
DPI_TRACE_ON_ANOMALY=false

LOG_LEVEL=INFO
