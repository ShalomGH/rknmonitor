DATABASE_URL=postgresql://rknmon:***@localhost:5432/rknmon
LOG_LEVEL=info

# Corporate proxy for internet egress from VPN
# PROXY_URL=http://proxy.corp:8080

# External vantage point (M3) — leave empty if not ready
# EXTERNAL_VANTAGE_URL=https://vantage.example.com/api/v1/probe
# EXTERNAL_VANTAGE_API_KEY=secret

PROBE_INTERVAL_MINUTES=10
PROBE_CONCURRENCY=50
