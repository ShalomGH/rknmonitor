upstream grafana {
    server rknmon_grafana:3000;
}

upstream prometheus {
    server rknmon_prometheus:9090;
}

# Rate limit только для API, не для статики Grafana.
# Grafana на первом открытии грузит много JS/CSS/font/svg параллельно — если лимитить всё,
# браузер получает 503 на application files.
limit_req_zone $binary_remote_addr zone=grafana_api:10m rate=50r/m;

server {
    listen 8443 ssl;
    server_name _;

    ssl_certificate /ssl/cert.pem;
    ssl_certificate_key /ssl/key.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;

    proxy_connect_timeout 15s;
    proxy_send_timeout 15s;
    proxy_read_timeout 60s;
    client_max_body_size 10m;

    # --- IP whitelist: replace examples with your admin/VPN/probe IPs before production ---
    allow 203.0.113.10;
    allow 198.51.100.10;
    allow 127.0.0.1;
    allow ::1;
    allow 10.0.0.0/8;
    allow 172.16.0.0/12;
    allow 192.168.0.0/16;
    deny all;

    # Grafana static assets — НЕ лимитируем, иначе Grafana падает с
    # "failed to load its application files".
    location /public/ {
        proxy_pass http://grafana;
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /avatar/ {
        proxy_pass http://grafana;
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Websocket Grafana Live — без rate-limit, иначе браузер получает 503.
    location /api/live/ {
        proxy_pass http://grafana;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # API Grafana — лимитируем, но с большим burst для первичной загрузки UI.
    location /api/ {
        limit_req zone=grafana_api burst=120 nodelay;
        proxy_pass http://grafana;
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Prometheus на пути /prometheus/
    location /prometheus/ {
        proxy_pass http://prometheus/;
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Grafana UI по умолчанию
    location / {
        proxy_pass http://grafana;
        proxy_set_header Host $http_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
